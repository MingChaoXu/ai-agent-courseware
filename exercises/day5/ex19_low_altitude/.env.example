# LLM Configuration
OPENAI_API_KEY=your-api-key-here
OPENAI_API_BASE=https://your-api-base/v1
OPENAI_MODEL_NAME=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2000

# CV Model (YOLOv8)
# First run auto-downloads yolov8n.pt (~6MB)
YOLO_MODEL=yolov8n.pt
YOLO_CONF_THRESHOLD=0.25
YOLO_DEVICE=cpu

# AMap (高德地图) API Key
# Apply at https://lbs.amap.com/ - leave empty for offline mode
AMAP_API_KEY=

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8300

# City Center (Chengdu)
CITY_CENTER_LAT=30.5728
CITY_CENTER_LNG=104.0668
