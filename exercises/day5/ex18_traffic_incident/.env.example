# Environment Variables Configuration
# Copy this file to .env and fill in your values

# LLM API Configuration
OPENAI_API_KEY=your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2000

# AMap (高德地图) API Key
# Optional: if set, uses real AMap APIs (geocoding, nearby search, traffic, routes)
# If not set, uses offline mock data for testing
# Apply at: https://lbs.amap.com/
AMAP_API_KEY=

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# History
MAX_HISTORY_TURNS=6
